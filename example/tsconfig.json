{
  "extends": "../tsconfig.json",
  "compilerOptions": {
    "plugins": [{ "name": "next" }],
    "noEmit": true,

    // === Path Aliases ===
    "paths": {
      "@example/*": ["./src/*"]
    }
  },
  "include": [
    "next-env.d.ts",
    "src/**/*.ts",
    "src/**/*.tsx",
    "src/**/*.mts",
    ".next/types/**/*.ts",
    ".next/dev/types/**/*.ts"
  ],
  "exclude": ["node_modules"]
}
