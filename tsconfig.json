{
  "compilerOptions": {
    // === Ignore baseUrl deprecation warning ===
    "ignoreDeprecations": "6.0",
    // === Language Level & Module Resolution ===
    "target": "ES2022", // Use modern ECMAScript target
    "lib": ["DOM", "DOM.Iterable", "ESNext", "WebWorker"], // Include common environments
    "module": "ESNext",
    "moduleResolution": "bundler",
    "jsx": "react-jsx", // Modern JSX transform (React 17+)

    // === Interoperability & Build Process ===
    "allowJs": true,
    "resolveJsonModule": true,
    "isolatedModules": true, // Required for Next.js/Babel compilation
    "esModuleInterop": true,
    "allowSyntheticDefaultImports": true, // Used alongside esModuleInterop
    "noEmit": true, // Type check only
    "incremental": true,
    
    // === Strictness & Safety Checks ===
    "strict": true, // Enable all strict checks
    "skipLibCheck": true, // Improve type-checking performance
    "forceConsistentCasingInFileNames": true, // CRITICAL for cross-OS portability

    // Explicit Strictness
    "noImplicitAny": true,
    "noImplicitThis": true,
    "noUncheckedIndexedAccess": true, // Enforce safer array/object access
    "noFallthroughCasesInSwitch": true, // Prevent accidental switch fallthrough
    "noImplicitReturns": true, // Ensure explicit returns in all code paths
    "noUnusedLocals": true, // Warn on unused local variables
    "noUnusedParameters": true, // Warn on unused parameters
  },
  "include": [
    "next-env.d.ts",
    "**/*.ts",
    "**/*.tsx",
    "**/*.mts",
    ".next/types/**/*.ts",
    ".next/dev/types/**/*.ts"
  ],
  "exclude": [
    "node_modules",
    "dist" // Exclude build output
  ]
}
